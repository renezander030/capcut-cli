{
  "name": "capcut-cli",
  "version": "0.2.0",
  "description": "CLI to create and edit CapCut projects — build drafts from scratch, add video/audio/text, subtitles, timing, speed, volume, templates, cut long-form to shorts. No API needed.",
  "type": "module",
  "bin": {
    "capcut": "dist/index.js",
    "capcut-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "node --import tsx src/index.ts"
  },
  "keywords": [
    "capcut",
    "capcut-editor",
    "capcut-draft",
    "capcut-srt",
    "capcut-subtitles",
    "capcut-json",
    "capcut-template",
    "capcut-automation",
    "capcut-api",
    "capcut-project",
    "jianying",
    "draft_content",
    "draft_info",
    "srt-export",
    "subtitle-editor",
    "video-to-shorts",
    "long-video-to-shorts",
    "batch-edit",
    "video-editing",
    "video-automation",
    "ai-video-editor",
    "mcp",
    "cli"
  ],
  "author": "René Zander",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renezander030/capcut-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
