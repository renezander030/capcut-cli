{
  "name": "capcut-cli",
  "version": "0.1.2",
  "description": "Fast CLI for editing CapCut projects. Edit text, timing, speed, and volume in seconds instead of minutes.",
  "type": "module",
  "bin": {
    "capcut": "dist/index.js",
    "capcut-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "node --import tsx src/index.ts"
  },
  "keywords": [
    "capcut",
    "jianying",
    "video-editing",
    "cli",
    "youtube",
    "youtube-shorts",
    "shorts",
    "reels",
    "tiktok",
    "subtitles",
    "srt",
    "captions",
    "timeline",
    "draft_content",
    "draft_info",
    "automation",
    "batch-edit",
    "templates",
    "ai-agent",
    "mcp"
  ],
  "author": "René Zander",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renezander030/capcut-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
